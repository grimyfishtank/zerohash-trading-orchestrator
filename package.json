{
  "name": "@zerohash/trading-orchestrator",
  "version": "1.0.0",
  "description": "Production-ready TypeScript orchestration layer for the ZeroHash Web SDK",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/grimyfishtank/zerohash-trading-orchestrator.git"
  },
  "peerDependencies": {
    "zh-web-sdk": ">=1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0",
    "zh-web-sdk": "^1.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
